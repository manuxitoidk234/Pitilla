        function showContent(tab) {
            document.querySelectorAll('.content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
            document.getElementById(tab).classList.add('active');
            event.currentTarget.classList.add('active');
            
            if (tab === 'quiz' && quizQuestions.length === 0) {
                startQuiz();
            }
        }

        function shuffle(arr) {
            return arr.sort(() => Math.random() - 0.5);
        }

        function startQuiz() {
            quizQuestions = shuffle([...allQuestions]);
            totalCount = allQuestions.length;
            currentIdx = 0;
            correctCount = 0;
            document.getElementById('results-container').style.display = 'none';
            document.getElementById('quiz-container').style.display = 'block';
            updateProgress();
            showQuestion();
        }

        function showQuestion() {
            const q = quizQuestions[currentIdx];
            document.getElementById('question-text').textContent = q.pregunta;
            document.getElementById('options-container').innerHTML = '';
            document.getElementById('feedback-panel').style.display = 'none';
            
            q.opciones.forEach(opt => {
                const btn = document.createElement('div');
                btn.className = 'option';
                btn.textContent = opt;
                btn.onclick = () => checkAnswer(opt, btn);
                document.getElementById('options-container').appendChild(btn);
            });
        }

        function checkAnswer(selected, btn) {
            const q = quizQuestions[currentIdx];
            const options = document.querySelectorAll('.option');
            options.forEach(o => o.onclick = null);

            const feedbackPanel = document.getElementById('feedback-panel');
            const status = document.getElementById('feedback-status');
            
            feedbackPanel.style.display = 'block';
            document.getElementById('explanation-text').textContent = q.explicacion;
            document.getElementById('citation-text').innerHTML = `<b>Cita del libro:</b> "${q.cita_textual}"`;
            document.getElementById('ref-image').src = IMAGE_PATH + q.imagen_referencia;

            if (selected === q.respuesta_correcta) {
                status.textContent = "¡Correcto! ✨";
                status.style.color = "var(--correct-color)";
                btn.style.borderColor = "var(--correct-color)";
                btn.style.backgroundColor = "#e8f5e9";
                correctCount++;
                currentIdx++;
            } else {
                status.textContent = "¡Casi lo logras! Mira la explicación abajo.";
                status.style.color = "var(--wrong-color)";
                btn.style.borderColor = "var(--wrong-color)";
                btn.style.backgroundColor = "#ffebee";
                
                // Si falla, insertamos una pregunta del mismo tema más adelante para reforzar
                const sameTopicQ = allQuestions.find((item, idx) => item.tema === q.tema && !quizQuestions.slice(0, currentIdx + 1).includes(item));
                if (sameTopicQ) {
                    quizQuestions.splice(currentIdx + 2, 0, sameTopicQ);
                    totalCount = quizQuestions.length;
                }
                
                // Mostrar la correcta
                options.forEach(o => {
                    if (o.textContent === q.respuesta_correcta) {
                        o.style.borderColor = "var(--correct-color)";
                        o.style.borderWidth = "3px";
                    }
                });
            }
            updateProgress();
        }

        function handleNext() {
            if (currentIdx < quizQuestions.length) {
                showQuestion();
            } else {
                showResults();
            }
        }

        function updateProgress() {
            const progress = (currentIdx / totalCount) * 100;
            const bar = document.getElementById('progress-bar');
            bar.style.width = progress + '%';
            bar.textContent = Math.round(progress) + '%';
        }

        function showResults() {
            document.getElementById('quiz-container').style.display = 'none';
            document.getElementById('results-container').style.display = 'block';
            document.getElementById('final-score').textContent = Math.round((correctCount / totalCount) * 100);
            document.getElementById('correct-count').textContent = correctCount;
            document.getElementById('total-count').textContent = totalCount;
        }

        function restartQuiz() {
            startQuiz();
        }
    </script>
</body>
</html>
